# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tool internals
.omc/

# 학생 개인정보 (PII) — 절대 커밋 금지 (아동 정보)
*.xlsx
# xlsx에서 생성되는 학생 시드 SQL(실명·연락처 포함) — 로컬 전용
/supabase/seed-local/
.gstack/
